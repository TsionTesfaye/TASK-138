	<string>DealerOps uses Face ID for quick and secure re-authentication.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DealerOps needs photo library access to attach evidence files to appeals.</string>
	<key>NSCameraUsageDescription</key>
	<string>DealerOps uses the camera to capture evidence photos.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DealerOps uses your location for check-ins and carpool matching.</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.dealerops.sla-check</string>
		<string>com.dealerops.media-cleanup</string>
		<string>com.dealerops.carpool-recalc</string>
		<string>com.dealerops.variance-processing</string>
		<string>com.dealerops.exception-detection</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
